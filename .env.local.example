# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin auth
ADMIN_PASSWORD=your-secure-password

# Zapier / external job creation (Bearer token for POST /api/jobs/create)
JOBS_API_KEY=generate-a-long-random-secret

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# Inngest (auto-set in dev when using Inngest Dev Server)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# App
BASE_URL=http://localhost:3000

# Dev only — override 90-min SMS delay (e.g. 1 = send after 1 minute)
DELAY_OVERRIDE_MINUTES=1
